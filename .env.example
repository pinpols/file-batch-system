# Copy this file to `.env.local` for local development.
# Copy to `.env.test` or `.env.prod` only if you need a separate environment template.

COMPOSE_PROJECT_NAME=batch-platform
# 全栈时区（唯一 env 源，见 CLAUDE.md §时区策略）：Spring batch.timezone / Jackson、BatchTimezoneProvider、
# docker-compose 的 TZ·PGTZ、本地 start-all.sh 导出的 JVM TZ 均由此推导。
BATCH_TIMEZONE_DEFAULT_ZONE=Asia/Shanghai
# 字符编码与进程 locale（唯一 env 源，见 CLAUDE.md §字符编码）：compose 里 LANG/LC_ALL、本机 JVM locale；
# 应用 HTTP/Message 字符集在 batch-defaults.yml 固定 UTF-8，须与此处 UTF-8 locale 一致。
BATCH_LOCALE=C.UTF-8

POSTGRES_IMAGE_TAG=16
POSTGRES_DB=batch_platform
POSTGRES_USER=batch_user
POSTGRES_PASSWORD=batch_pass_123
POSTGRES_PORT=15432
BUSINESS_DB_NAME=batch_business
BUSINESS_DB_SCHEMA=biz

# P2-4 读写分离（默认启用，与 application.yml + docker-compose 一致）
# 启动从库：docker compose --profile replica up -d postgres-replica
# 关闭路由（不需要从库时）：BATCH_CONSOLE_READ_REPLICA_ENABLED=false 重启 console-api
# fail-open 已就位：从库连续 N 次失败后自动隔离，路由降级到主库，不影响请求成功
# 主库流复制配置已在 docker-compose.yml 写死（wal_level / max_wal_senders 等），
# 即使不开 replica 也无副作用（仅多消耗少量 WAL 缓冲）。
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=repl_pass_dev_only
POSTGRES_REPLICA_PORT=15433
BATCH_CONSOLE_READ_REPLICA_ENABLED=true
# 容器内地址：postgres-replica:5432；宿主机调试用 localhost:15433
BATCH_CONSOLE_REPLICA_URL=jdbc:postgresql://postgres-replica:5432/batch_platform
BATCH_CONSOLE_REPLICA_USER=batch_user
BATCH_CONSOLE_REPLICA_PASSWORD=batch_pass_123

# Phase 2 其他开关（默认全开 + fail-open 兜底；详见 docs/runbook/feature-switches.md）
# BATCH_SCHEDULER_WORKER_CACHE_ENABLED=true       # WorkerSelector Redis 5s cache
# BATCH_MQ_ROUTING_MODE=TENANT                    # SINGLE / TENANT / PRIORITY
# BATCH_QUOTA_RUNTIME_STORE=redis                 # redis / database
# BATCH_TRIGGER_SCHEDULER_IMPL=wheel              # wheel(2026-04-26 起为默认) / quartz(显式回退)
#
# 注：原 BATCH_TRIGGER_QUARTZ_DATASOURCE_* 已于 2026-04-25 移除（Phase 2 半成品清理）。
# Quartz JobStore 共享主 DataSource；2026-04-26 起 wheel 已切为默认调度引擎，
# Quartz codepath 仅作 incident 回退保留（显式 BATCH_TRIGGER_SCHEDULER_IMPL=quartz）。
# 详见 docs/runbook/wheel-scheduler-rollout.md。

KAFKA_IMAGE_TAG=4.1.2
KAFKA_HOST_PORT=19092
# 本地开发保持 3 分区（单机足够）。
# 生产环境分区数 = 预期最大 Worker 实例数 × concurrency（如 10 实例 × 4 并发 = 40）。
# Kafka 分区数只能增加不能减少，投产前按容量规划一次性设置到位。
# dispatch topic 分区数决定消费吞吐上限；result/retry/dead-letter 流量远低于 dispatch，可设较小值。
KAFKA_DEFAULT_PARTITIONS=3
# 如需为各 topic 单独设置分区数，可拆分为以下变量（需配合 docker-compose 中的 topic 创建脚本）：
# KAFKA_PARTITIONS_DISPATCH=40   # import/export/process/dispatch 派发 topic
# KAFKA_PARTITIONS_RESULT=20     # 结果回报 topic（worker → orchestrator）
# KAFKA_PARTITIONS_RETRY=10      # 重试调度 topic
# KAFKA_PARTITIONS_DEAD_LETTER=5 # 死信 topic
KAFKA_TOPICS=batch.task.dispatch.import,batch.task.dispatch.export,batch.task.dispatch.process,batch.task.dispatch.dispatch,batch.task.dispatch.task,batch.task.result,batch.task.retry,batch.task.dead-letter,batch.trigger.launch.v1,batch.verifier.failure.v1

MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
# 注意:MinIO 团队不再把 GitHub release tag 全部推 Docker Hub。
# Docker Hub 最新可用 tag 为 RELEASE.2025-09-07T16-13-09Z(2025-10-15 没推 Docker Hub)。
MINIO_IMAGE_TAG=RELEASE.2025-09-07T16-13-09Z
REDIS_IMAGE_TAG=7.4
MINIO_MC_IMAGE_TAG=RELEASE.2025-07-16T15-35-03Z
MINIO_PROMETHEUS_AUTH_TYPE=public
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=batch-dev

PROMETHEUS_PORT=19090
PROMETHEUS_IMAGE_TAG=v2.55.1
REDIS_EXPORTER_PORT=19121
REDIS_EXPORTER_IMAGE_TAG=v1.67.0
POSTGRES_EXPORTER_PORT=19187
POSTGRES_EXPORTER_IMAGE_TAG=v0.15.0
KAFKA_EXPORTER_PORT=19308
KAFKA_EXPORTER_IMAGE_TAG=v1.8.0
NODE_EXPORTER_PORT=19100
NODE_EXPORTER_IMAGE_TAG=v1.8.1
CADVISOR_PORT=19101
CADVISOR_IMAGE_TAG=v0.52.1

# 可观测性 UI（宿主机映射，与 18xxx/19xxx 端口族一致）
GRAFANA_PORT=13000
LOKI_PORT=13100
TEMPO_HTTP_PORT=13200
JAEGER_UI_PORT=16686

BATCH_CONSOLE_INSTANCE_ID=batch-console-api-local
BATCH_CONSOLE_REALTIME_REPLAY_MAX_ENTRIES=20000
BATCH_CONSOLE_REALTIME_REPLAY_TTL=24h
OPENAI_API_KEY=local-dummy-openai-key
BATCH_REDIS_HOST=redis
BATCH_REDIS_PORT=16379

# 全链路安全旁路（放宽认证/脱敏/加解密/审批/渠道校验）；见 CLAUDE.md §配置开关规范。
# docker-compose 默认 false（接近生产形态）；IDE 本地 application-local.yml 默认 true（开发者调试方便）；
# 生产必须 false 且 @PostConstruct 守护。
BATCH_SECURITY_BYPASS_MODE=false
# Spring profile。fail-secure:空/未知 profile 当生产。本地/联调设 local;生产设 prod(届时 bypass 必须 false)。
SPRING_PROFILES_ACTIVE=local
# /internal/** 服务间调用共享密钥。docker-compose app 栈强制要求显式配置,避免落回默认 internal-secret。
BATCH_INTERNAL_SECRET=change-me-please-32-chars
CONSOLE_API_PORT=18080
TRIGGER_PORT=18081
ORCHESTRATOR_PORT=18082
REDIS_PORT=16379

# 本机直跑 Spring Boot（非 app 容器）时：Java 服务端口默认 18080–18086，与 docker/compose/app.yml 宿主机映射一致。
# 端口分配:console-api=18080 / trigger=18081 / orchestrator=18082 / worker-import=18083 /
# worker-export=18084 / worker-dispatch=18085 / worker-process=18086

# Docker Compose：限制 JVM 堆，避免 Java 25 默认占用过大内存导致宿主机 OOM、容器 exit 137（可按机器内存覆盖）
# BATCH_APP_JAVA_OPTS=--enable-native-access=ALL-UNNAMED -Xms128m -Xmx512m -XX:MaxMetaspaceSize=192m
# BATCH_ORCHESTRATOR_JAVA_OPTS=--enable-native-access=ALL-UNNAMED -Xms256m -Xmx768m -XX:MaxMetaspaceSize=256m
