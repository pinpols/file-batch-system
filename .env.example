# Copy this file to `.env.local` for local development.
# Copy to `.env.test` or `.env.prod` only if you need a separate environment template.

COMPOSE_PROJECT_NAME=batch-local
TZ=Asia/Shanghai

POSTGRES_IMAGE_TAG=16
POSTGRES_DB=batch_platform
POSTGRES_USER=batch_user
POSTGRES_PASSWORD=batch_pass_123
POSTGRES_PORT=15432
BUSINESS_DB_NAME=batch_business
BUSINESS_DB_SCHEMA=biz

KAFKA_IMAGE_TAG=4.1.2
KAFKA_HOST_PORT=19092
# 本地开发保持 3 分区（单机足够）。
# 生产环境分区数 = 预期最大 Worker 实例数 × concurrency（如 10 实例 × 4 并发 = 40）。
# Kafka 分区数只能增加不能减少，投产前按容量规划一次性设置到位。
# dispatch topic 分区数决定消费吞吐上限；result/retry/dead-letter 流量远低于 dispatch，可设较小值。
KAFKA_DEFAULT_PARTITIONS=3
# 如需为各 topic 单独设置分区数，可拆分为以下变量（需配合 docker-compose 中的 topic 创建脚本）：
# KAFKA_PARTITIONS_DISPATCH=40   # import/export/dispatch 派发 topic
# KAFKA_PARTITIONS_RESULT=20     # 结果回报 topic（worker → orchestrator）
# KAFKA_PARTITIONS_RETRY=10      # 重试调度 topic
# KAFKA_PARTITIONS_DEAD_LETTER=5 # 死信 topic
KAFKA_TOPICS=batch.task.dispatch.import,batch.task.dispatch.export,batch.task.dispatch.dispatch,batch.task.result,batch.task.retry,batch.task.dead-letter

MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
MINIO_IMAGE_TAG=RELEASE.2025-04-03T14-56-28Z
MINIO_MC_IMAGE_TAG=RELEASE.2025-07-16T15-35-03Z
MINIO_PROMETHEUS_AUTH_TYPE=public
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=batch-dev

PROMETHEUS_PORT=19090
PROMETHEUS_IMAGE_TAG=v2.55.1
REDIS_EXPORTER_PORT=19121
REDIS_EXPORTER_IMAGE_TAG=v1.67.0
POSTGRES_EXPORTER_PORT=19187
POSTGRES_EXPORTER_IMAGE_TAG=v0.15.0
KAFKA_EXPORTER_PORT=19308
KAFKA_EXPORTER_IMAGE_TAG=v1.8.0
NODE_EXPORTER_PORT=19100
NODE_EXPORTER_IMAGE_TAG=v1.8.1
CADVISOR_PORT=19101
CADVISOR_IMAGE_TAG=v0.49.1

# 可观测性 UI（宿主机映射，与 18xxx/19xxx 端口族一致）
GRAFANA_PORT=13000
LOKI_PORT=13100
JAEGER_UI_PORT=16686

BATCH_CONSOLE_INSTANCE_ID=batch-console-api-local
BATCH_CONSOLE_REALTIME_REPLAY_MAX_ENTRIES=20000
BATCH_CONSOLE_REALTIME_REPLAY_TTL=24h
OPENAI_API_KEY=local-dummy-openai-key
BATCH_REDIS_HOST=redis
BATCH_REDIS_PORT=16379
CONSOLE_API_PORT=18080
TRIGGER_PORT=18081
ORCHESTRATOR_PORT=18082
REDIS_PORT=16379

# 本机直跑 Spring Boot（非 app 容器）时：Java 服务端口默认 18080–18085，与 docker-compose.app.yml 宿主机映射一致。

# Docker Compose：限制 JVM 堆，避免 Java 25 默认占用过大内存导致宿主机 OOM、容器 exit 137（可按机器内存覆盖）
# BATCH_APP_JAVA_OPTS=--enable-native-access=ALL-UNNAMED -Xms128m -Xmx512m -XX:MaxMetaspaceSize=192m
# BATCH_ORCHESTRATOR_JAVA_OPTS=--enable-native-access=ALL-UNNAMED -Xms256m -Xmx768m -XX:MaxMetaspaceSize=256m
