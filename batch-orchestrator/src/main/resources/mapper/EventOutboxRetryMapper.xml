<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.batch.orchestrator.mapper.EventOutboxRetryMapper">
    <resultMap id="EventOutboxRetryResultMap" type="com.example.batch.orchestrator.domain.entity.EventOutboxRetryEntity">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="outbox_event_id" property="outboxEventId"/>
        <result column="event_key" property="eventKey"/>
        <result column="retry_attempt" property="publishAttempt"/>
        <result column="retry_status" property="retryStatus"/>
        <result column="retry_reason" property="retryReason"/>
        <result column="next_retry_at" property="nextRetryAt"/>
        <result column="trace_id" property="traceId"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.batch.orchestrator.domain.entity.EventOutboxRetryEntity"
            useGeneratedKeys="true" keyProperty="id">
        insert into batch.event_outbox_retry (
            tenant_id,
            outbox_event_id,
            event_key,
            retry_attempt,
            retry_status,
            retry_reason,
            next_retry_at,
            trace_id
        ) values (
            #{tenantId},
            #{outboxEventId},
            #{eventKey},
            #{publishAttempt},
            #{retryStatus},
            #{retryReason},
            #{nextRetryAt},
            #{traceId}
        )
    </insert>

    <select id="selectByQuery" resultMap="EventOutboxRetryResultMap">
        select *
        from batch.event_outbox_retry
        where 1 = 1
        <if test="tenantId != null and tenantId != ''">
            and tenant_id = #{tenantId}
        </if>
        <if test="retryStatus != null and retryStatus != ''">
            and retry_status = #{retryStatus}
        </if>
        <if test="eventKey != null and eventKey != ''">
            and event_key = #{eventKey}
        </if>
        order by id desc
    </select>
</mapper>
