<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.batch.orchestrator.mapper.JobDefinitionMapper">
    <!--
      JobDefinitionEntity 是 java record（不可变），用 <constructor> 显式映射构造器参数。
      参数顺序必须与 record canonical constructor 完全一致：
        (id, tenantId, jobCode, jobName, jobType, bizType,
         scheduleType, scheduleExpr, timezone, workerGroup, queueCode, calendarCode,
         windowCode, triggerMode, dagEnabled, shardStrategy, retryPolicy, retryMaxCount,
         timeoutSeconds, executionHandler, paramSchema, priority, defaultParams,
         version, enabled, description, executionMode, watermarkField, previousDayDependencyScope)

      param_schema / default_params 是 JSONB；读路径通过 ::text 转字符串再走 MapJsonbTypeHandler。
    -->
    <resultMap id="jobDefinitionMap"
               type="com.example.batch.orchestrator.domain.entity.JobDefinitionEntity">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="tenant_id" javaType="java.lang.String"/>
            <arg column="job_code" javaType="java.lang.String"/>
            <arg column="job_name" javaType="java.lang.String"/>
            <arg column="job_type" javaType="java.lang.String"/>
            <arg column="biz_type" javaType="java.lang.String"/>
            <arg column="schedule_type" javaType="java.lang.String"/>
            <arg column="schedule_expr" javaType="java.lang.String"/>
            <arg column="timezone" javaType="java.lang.String"/>
            <arg column="worker_group" javaType="java.lang.String"/>
            <arg column="queue_code" javaType="java.lang.String"/>
            <arg column="calendar_code" javaType="java.lang.String"/>
            <arg column="window_code" javaType="java.lang.String"/>
            <arg column="trigger_mode" javaType="java.lang.String"/>
            <arg column="dag_enabled" javaType="java.lang.Boolean"/>
            <arg column="shard_strategy" javaType="java.lang.String"/>
            <arg column="retry_policy" javaType="java.lang.String"/>
            <arg column="retry_max_count" javaType="java.lang.Integer"/>
            <arg column="timeout_seconds" javaType="java.lang.Integer"/>
            <arg column="execution_handler" javaType="java.lang.String"/>
            <arg column="param_schema_text"
                 javaType="java.util.Map"
                 typeHandler="com.example.batch.orchestrator.infrastructure.mybatis.MapJsonbTypeHandler"/>
            <arg column="priority" javaType="java.lang.Integer"/>
            <arg column="default_params_text"
                 javaType="java.util.Map"
                 typeHandler="com.example.batch.orchestrator.infrastructure.mybatis.MapJsonbTypeHandler"/>
            <arg column="version" javaType="java.lang.Integer"/>
            <arg column="enabled" javaType="java.lang.Boolean"/>
            <arg column="description" javaType="java.lang.String"/>
            <arg column="execution_mode" javaType="java.lang.String"/>
            <arg column="watermark_field" javaType="java.lang.String"/>
            <arg column="previous_day_dependency_scope" javaType="java.lang.String"/>
            <arg column="job_group_code" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <sql id="selectColumns">
        id, tenant_id, job_code, job_name, job_type, biz_type,
        schedule_type, schedule_expr, timezone, worker_group, queue_code, calendar_code,
        window_code, trigger_mode, dag_enabled, shard_strategy, retry_policy, retry_max_count,
        timeout_seconds, execution_handler,
        param_schema::text AS param_schema_text,
        priority,
        default_params::text AS default_params_text,
        version, enabled, description, execution_mode, watermark_field,
        previous_day_dependency_scope, job_group_code
    </sql>

    <select id="selectFirstByTenantAndCodeAndEnabled" resultMap="jobDefinitionMap">
        select <include refid="selectColumns"/>
          from batch.job_definition
         where tenant_id = #{tenantId}
           and job_code = #{jobCode}
           and enabled = #{enabled}
         order by version desc, id desc
         limit 1
    </select>

    <select id="selectByTenantAndEnabled" resultMap="jobDefinitionMap">
        select <include refid="selectColumns"/>
          from batch.job_definition
         where tenant_id = #{tenantId}
           and enabled = #{enabled}
         order by id desc
    </select>

    <select id="selectById" resultMap="jobDefinitionMap">
        select <include refid="selectColumns"/>
          from batch.job_definition
         where id = #{id}
    </select>
</mapper>
