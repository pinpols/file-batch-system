<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.batch.orchestrator.mapper.WorkflowEdgeMapper">
    <resultMap id="WorkflowEdgeResultMap" type="com.example.batch.orchestrator.domain.entity.WorkflowEdgeEntity">
        <id column="id" property="id"/>
        <result column="workflow_definition_id" property="workflowDefinitionId"/>
        <result column="from_node_code" property="fromNodeCode"/>
        <result column="to_node_code" property="toNodeCode"/>
        <result column="edge_type" property="edgeType"/>
        <result column="condition_expr" property="conditionExpr"/>
        <result column="enabled" property="enabled"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectOutgoingEdges" resultMap="WorkflowEdgeResultMap">
        select *
        from batch.workflow_edge
        where workflow_definition_id = #{workflowDefinitionId}
          and from_node_code = #{fromNodeCode}
          and enabled = true
        order by id asc
    </select>

    <select id="selectIncomingEdges" resultMap="WorkflowEdgeResultMap">
        select *
        from batch.workflow_edge
        where workflow_definition_id = #{workflowDefinitionId}
          and to_node_code = #{toNodeCode}
          and enabled = true
        order by id asc
    </select>
</mapper>
