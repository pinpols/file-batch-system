<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.batch.orchestrator.mapper.auth.ApiKeyAuthMapper">

    <resultMap id="apiKeyRecordMap" type="com.example.batch.orchestrator.auth.ApiKeyRecord">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="tenant_id" javaType="java.lang.String"/>
            <arg column="key_name" javaType="java.lang.String"/>
            <arg column="scopes" javaType="java.lang.String"/>
            <arg column="enabled" javaType="java.lang.Boolean"/>
            <arg column="expires_at" javaType="java.time.Instant"/>
        </constructor>
    </resultMap>

    <select id="findActiveByHashAndTenant" resultMap="apiKeyRecordMap">
        select id, tenant_id, key_name, scopes, enabled, expires_at
        from batch.api_key
        where key_hash = #{keyHash}
          and tenant_id = #{tenantId}
          and enabled = true
          and (expires_at is null or expires_at > now())
          and revoked_at is null
        limit 1
    </select>

    <update id="touchLastUsedAt">
        update batch.api_key set last_used_at = now() where id = #{id}
    </update>

</mapper>
