<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.batch.orchestrator.mapper.TenantRoutingMapper">

    <select id="selectActiveTenantIds" resultType="string">
        select tenant_id
        from batch.tenant
        where status = 'ACTIVE'
        order by 1
    </select>

</mapper>
