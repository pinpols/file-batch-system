<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.pinpols.batch.orchestrator.mapper.TenantQuotaPolicyMapper">
    <!--
      TenantQuotaPolicyEntity 是 java record（不可变），用 <constructor> 显式映射构造器参数。
      参数顺序必须与 record canonical constructor 完全一致：
        (id, tenantId, policyCode, maxRunningJobsPerTenant, maxPartitionsPerTenant,
         maxQpsPerTenant, fairShareWeight, fairShareGroup, burstLimit, partitionBurstLimit,
         quotaResetPolicy, groupSharedMaxRunningJobs, enabled, exceededStrategy)
    -->
    <resultMap id="tenantQuotaPolicyMap"
               type="io.github.pinpols.batch.orchestrator.domain.entity.TenantQuotaPolicyEntity">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="tenant_id" javaType="java.lang.String"/>
            <arg column="policy_code" javaType="java.lang.String"/>
            <arg column="max_running_jobs_per_tenant" javaType="java.lang.Integer"/>
            <arg column="max_partitions_per_tenant" javaType="java.lang.Integer"/>
            <arg column="max_qps_per_tenant" javaType="java.lang.Integer"/>
            <arg column="fair_share_weight" javaType="java.lang.Integer"/>
            <arg column="fair_share_group" javaType="java.lang.String"/>
            <arg column="burst_limit" javaType="java.lang.Integer"/>
            <arg column="partition_burst_limit" javaType="java.lang.Integer"/>
            <arg column="quota_reset_policy" javaType="java.lang.String"/>
            <arg column="group_shared_max_running_jobs" javaType="java.lang.Integer"/>
            <arg column="enabled" javaType="java.lang.Boolean"/>
            <arg column="exceeded_strategy" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <sql id="columns">
        id, tenant_id, policy_code,
        max_running_jobs_per_tenant, max_partitions_per_tenant, max_qps_per_tenant,
        fair_share_weight, fair_share_group, burst_limit, partition_burst_limit,
        quota_reset_policy, group_shared_max_running_jobs, enabled, exceeded_strategy
    </sql>

    <select id="selectByTenantAndEnabled" resultMap="tenantQuotaPolicyMap">
        select <include refid="columns"/>
          from batch.tenant_quota_policy
         where tenant_id = #{tenantId}
           and enabled = #{enabled}
         order by id asc
    </select>

    <select id="selectFirstEnabledByTenantId" resultMap="tenantQuotaPolicyMap">
        select <include refid="columns"/>
          from batch.tenant_quota_policy
         where tenant_id = #{tenantId}
           and enabled = #{enabled}
         order by id asc
         limit 1
    </select>

    <select id="selectDistinctEnabledTenantIds" resultType="java.lang.String">
        select distinct tenant_id from batch.tenant_quota_policy where enabled = true
    </select>

    <select id="selectById" resultMap="tenantQuotaPolicyMap">
        select <include refid="columns"/>
          from batch.tenant_quota_policy
         where id = #{id}
    </select>
</mapper>
