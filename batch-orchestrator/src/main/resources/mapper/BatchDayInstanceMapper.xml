<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.batch.orchestrator.mapper.BatchDayInstanceMapper">
    <!--
      BatchDayInstanceEntity 是 java record（不可变），用 <constructor> 显式映射构造器参数。
      参数顺序必须与 record canonical constructor 完全一致：
        (id, tenantId, calendarCode, bizDate, dayStatus, openAt, cutoffAt, settledAt,
         slaDeadlineAt, lateCount, catchupCount, timezoneSnapshot, version, createdAt, updatedAt)
      列名按 V32 + V62 DDL。
    -->
    <resultMap id="batchDayInstanceMap"
               type="com.example.batch.orchestrator.domain.entity.BatchDayInstanceEntity">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="tenant_id" javaType="java.lang.String"/>
            <arg column="calendar_code" javaType="java.lang.String"/>
            <arg column="biz_date" javaType="java.time.LocalDate"/>
            <arg column="day_status" javaType="java.lang.String"/>
            <arg column="open_at" javaType="java.time.Instant"/>
            <arg column="cutoff_at" javaType="java.time.Instant"/>
            <arg column="settled_at" javaType="java.time.Instant"/>
            <arg column="sla_deadline_at" javaType="java.time.Instant"/>
            <arg column="late_count" javaType="java.lang.Integer"/>
            <arg column="catchup_count" javaType="java.lang.Integer"/>
            <arg column="timezone_snapshot" javaType="java.lang.String"/>
            <arg column="version" javaType="java.lang.Long"/>
            <arg column="created_at" javaType="java.time.Instant"/>
            <arg column="updated_at" javaType="java.time.Instant"/>
        </constructor>
    </resultMap>

    <insert id="insert"
            parameterType="com.example.batch.orchestrator.domain.entity.BatchDayInstanceEntity">
        insert into batch.batch_day_instance (
            tenant_id, calendar_code, biz_date, day_status,
            open_at, cutoff_at, settled_at, sla_deadline_at,
            late_count, catchup_count, timezone_snapshot,
            version, created_at, updated_at
        ) values (
            #{tenantId}, #{calendarCode}, #{bizDate},
            <choose>
                <when test="dayStatus != null">#{dayStatus}</when>
                <otherwise>'OPEN'</otherwise>
            </choose>,
            <choose>
                <when test="openAt != null">#{openAt}</when>
                <otherwise>current_timestamp</otherwise>
            </choose>,
            #{cutoffAt}, #{settledAt}, #{slaDeadlineAt},
            <choose>
                <when test="lateCount != null">#{lateCount}</when>
                <otherwise>0</otherwise>
            </choose>,
            <choose>
                <when test="catchupCount != null">#{catchupCount}</when>
                <otherwise>0</otherwise>
            </choose>,
            <choose>
                <when test="timezoneSnapshot != null">#{timezoneSnapshot}</when>
                <otherwise>'UTC'</otherwise>
            </choose>,
            <choose>
                <when test="version != null">#{version}</when>
                <otherwise>0</otherwise>
            </choose>,
            <choose>
                <when test="createdAt != null">#{createdAt}</when>
                <otherwise>current_timestamp</otherwise>
            </choose>,
            <choose>
                <when test="updatedAt != null">#{updatedAt}</when>
                <otherwise>current_timestamp</otherwise>
            </choose>
        )
        on conflict (tenant_id, calendar_code, biz_date) do nothing
    </insert>

    <update id="updateWithCas"
            parameterType="com.example.batch.orchestrator.domain.entity.BatchDayInstanceEntity">
        update batch.batch_day_instance
           set day_status         = #{dayStatus},
               open_at             = #{openAt},
               cutoff_at           = #{cutoffAt},
               settled_at          = #{settledAt},
               sla_deadline_at     = #{slaDeadlineAt},
               late_count          = #{lateCount},
               catchup_count       = #{catchupCount},
               timezone_snapshot   = #{timezoneSnapshot},
               updated_at          = current_timestamp,
               version             = version + 1
         where id = #{id}
           and version = #{version}
    </update>

    <select id="selectByTenantCalendarBizDate" resultMap="batchDayInstanceMap">
        select *
          from batch.batch_day_instance
         where tenant_id = #{tenantId}
           and calendar_code = #{calendarCode}
           and biz_date = #{bizDate}
    </select>

    <select id="selectByDayStatusIn" resultMap="batchDayInstanceMap">
        select *
          from batch.batch_day_instance
         where day_status in
        <foreach collection="dayStatuses" item="status" open="(" separator="," close=")">
            #{status}
        </foreach>
        order by biz_date desc
    </select>
</mapper>
