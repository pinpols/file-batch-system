<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.pinpols.batch.console.domain.workflow.mapper.WorkflowRunMapper">
    <resultMap id="WorkflowRunResultMap" type="io.github.pinpols.batch.common.persistence.entity.WorkflowRunEntity">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="workflow_definition_id" property="workflowDefinitionId"/>
        <result column="related_job_instance_id" property="relatedJobInstanceId"/>
        <result column="biz_date" property="bizDate"/>
        <result column="run_status" property="runStatus"/>
        <result column="current_node_code" property="currentNodeCode"/>
        <result column="trace_id" property="traceId"/>
        <result column="started_at" property="startedAt"/>
        <result column="finished_at" property="finishedAt"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="dry_run" property="dryRun"/>
    </resultMap>

    <select id="selectByQuery" resultMap="WorkflowRunResultMap">
        select *
        from batch.workflow_run
        where tenant_id = #{tenantId}
        <if test="cursorId != null">
            and id &lt; #{cursorId}
        </if>
        <if test="workflowDefinitionId != null">
            and workflow_definition_id = #{workflowDefinitionId}
        </if>
        <if test="relatedJobInstanceId != null">
            and related_job_instance_id = #{relatedJobInstanceId}
        </if>
        <if test="runStatus != null and runStatus != ''">
            and run_status = #{runStatus}
        </if>
        <if test="currentNodeCode != null and currentNodeCode != ''">
            and current_node_code = #{currentNodeCode}
        </if>
        <if test="traceId != null and traceId != ''">
            and trace_id like concat('%', #{traceId}, '%')
        </if>
        order by id desc
        <choose>
            <when test="cursorId != null">
                limit #{pageRequest.pageSize}
            </when>
            <otherwise>
                <include refid="io.github.pinpols.batch.common.mapper.CommonFragments.offsetPageClause"/>
            </otherwise>
        </choose>
    </select>

    <select id="selectById" resultMap="WorkflowRunResultMap">
        select *
        from batch.workflow_run
        where tenant_id = #{tenantId}
          and id = #{id}
    </select>

    <select id="countByQuery" resultType="long">
        select count(1)
        from batch.workflow_run
        where tenant_id = #{tenantId}
        <if test="workflowDefinitionId != null">
            and workflow_definition_id = #{workflowDefinitionId}
        </if>
        <if test="relatedJobInstanceId != null">
            and related_job_instance_id = #{relatedJobInstanceId}
        </if>
        <if test="runStatus != null and runStatus != ''">
            and run_status = #{runStatus}
        </if>
        <if test="currentNodeCode != null and currentNodeCode != ''">
            and current_node_code = #{currentNodeCode}
        </if>
        <if test="traceId != null and traceId != ''">
            and trace_id like concat('%', #{traceId}, '%')
        </if>
    </select>

    <select id="countByStatuses" resultType="long">
        select count(*)
          from batch.workflow_run
         where tenant_id = #{tenantId}
           and run_status in
        <foreach collection="statuses" item="s" open="(" close=")" separator=",">#{s}</foreach>
    </select>
</mapper>
