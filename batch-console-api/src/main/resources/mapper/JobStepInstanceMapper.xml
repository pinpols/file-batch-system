<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.pinpols.batch.console.domain.job.mapper.JobStepInstanceMapper">
    <resultMap id="JobStepInstanceResultMap" type="io.github.pinpols.batch.console.domain.job.entity.JobStepInstanceEntity">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="job_instance_id" property="jobInstanceId"/>
        <result column="job_partition_id" property="jobPartitionId"/>
        <result column="job_task_id" property="jobTaskId"/>
        <result column="step_code" property="stepCode"/>
        <result column="step_type" property="stepType"/>
        <result column="step_status" property="stepStatus"/>
        <result column="retry_count" property="retryCount"/>
        <result column="related_file_id" property="relatedFileId"/>
        <result column="result_summary" property="resultSummary"/>
        <result column="error_code" property="errorCode"/>
        <result column="error_message" property="errorMessage"/>
        <result column="error_key" property="errorKey"/>
        <result column="error_args" property="errorArgs"/>
        <result column="related_pipeline_instance_id" property="relatedPipelineInstanceId"/>
        <result column="started_at" property="startedAt"/>
        <result column="finished_at" property="finishedAt"/>
    </resultMap>

    <!--
      缺口4:作业入口→pipeline 观测跳转。反查 pipeline_instance.related_job_instance_id 得到该 step 所属 job
      的 pipeline_instance id;文件类 job 才有值,普通 job 为 null。相关性由 (tenant_id, related_job_instance_id)
      索引支撑,取最近一个。
    -->
    <sql id="relatedPipelineInstanceIdColumn">
        (select pi.id
         from batch.pipeline_instance pi
         where pi.related_job_instance_id = s.job_instance_id
           and pi.tenant_id = s.tenant_id
         order by pi.id desc
         limit 1) as related_pipeline_instance_id
    </sql>

    <select id="selectByQuery" resultMap="JobStepInstanceResultMap">
        select s.*, <include refid="relatedPipelineInstanceIdColumn"/>
        from batch.job_step_instance s
        where tenant_id = #{tenantId}
        <if test="cursorId != null">
            and id &lt; #{cursorId}
        </if>
        <if test="jobInstanceId != null">
            and job_instance_id = #{jobInstanceId}
        </if>
        <if test="jobPartitionId != null">
            and job_partition_id = #{jobPartitionId}
        </if>
        <if test="stepCode != null and stepCode != ''">
            and step_code = #{stepCode}
        </if>
        <if test="stepStatus != null and stepStatus != ''">
            and step_status = #{stepStatus}
        </if>
        order by id desc
        <choose>
            <when test="cursorId != null">
                limit #{pageRequest.pageSize}
            </when>
            <otherwise>
                <include refid="io.github.pinpols.batch.common.mapper.CommonFragments.offsetPageClause"/>
            </otherwise>
        </choose>
    </select>

    <select id="selectById" resultMap="JobStepInstanceResultMap">
        select s.*, <include refid="relatedPipelineInstanceIdColumn"/>
        from batch.job_step_instance s
        where tenant_id = #{tenantId}
          and id = #{id}
    </select>

    <select id="countByQuery" resultType="long">
        select count(1)
        from batch.job_step_instance
        where tenant_id = #{tenantId}
        <if test="jobInstanceId != null">
            and job_instance_id = #{jobInstanceId}
        </if>
        <if test="jobPartitionId != null">
            and job_partition_id = #{jobPartitionId}
        </if>
        <if test="stepCode != null and stepCode != ''">
            and step_code = #{stepCode}
        </if>
        <if test="stepStatus != null and stepStatus != ''">
            and step_status = #{stepStatus}
        </if>
    </select>
</mapper>
