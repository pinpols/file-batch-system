<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.batch.console.mapper.RetryScheduleMapper">
    <resultMap id="RetryScheduleResultMap" type="com.example.batch.console.domain.entity.RetryScheduleEntity">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="related_type" property="relatedType"/>
        <result column="related_id" property="relatedId"/>
        <result column="retry_policy" property="retryPolicy"/>
        <result column="retry_count" property="retryCount"/>
        <result column="max_retry_count" property="maxRetryCount"/>
        <result column="next_retry_at" property="nextRetryAt"/>
        <result column="retry_status" property="retryStatus"/>
        <result column="dedup_key" property="dedupKey"/>
        <result column="last_error_code" property="lastErrorCode"/>
        <result column="last_error_message" property="lastErrorMessage"/>
        <result column="last_error_key" property="lastErrorKey"/>
        <result column="last_error_args" property="lastErrorArgs"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectByQuery" resultMap="RetryScheduleResultMap">
        select *
        from batch.retry_schedule
        where tenant_id = #{tenantId}
        <if test="relatedType != null and relatedType != ''">
            and related_type = #{relatedType}
        </if>
        <if test="retryPolicy != null and retryPolicy != ''">
            and retry_policy = #{retryPolicy}
        </if>
        <if test="retryStatus != null and retryStatus != ''">
            and retry_status = #{retryStatus}
        </if>
        order by next_retry_at asc, id desc
        <include refid="com.example.batch.common.mapper.CommonFragments.offsetPageClause"/>
    </select>

    <select id="countByQuery" resultType="long">
        select count(1)
        from batch.retry_schedule
        where tenant_id = #{tenantId}
        <if test="relatedType != null and relatedType != ''">
            and related_type = #{relatedType}
        </if>
        <if test="retryPolicy != null and retryPolicy != ''">
            and retry_policy = #{retryPolicy}
        </if>
        <if test="retryStatus != null and retryStatus != ''">
            and retry_status = #{retryStatus}
        </if>
    </select>
</mapper>
