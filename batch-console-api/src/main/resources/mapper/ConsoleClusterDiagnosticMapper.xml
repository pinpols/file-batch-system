<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.batch.console.mapper.ConsoleClusterDiagnosticMapper">

    <!-- record 投影：用 <constructor> 显式按 canonical constructor 入参顺序绑定列;
         避免依赖 MyBatis 的 mapUnderscoreToCamelCase / 参数名反射,跨 JDK / 编译开关稳定。 -->
    <resultMap id="ShedLockResultMap" type="com.example.batch.console.domain.view.cluster.ShedLockView">
        <constructor>
            <idArg column="name" javaType="java.lang.String"/>
            <arg column="lock_until" javaType="java.time.Instant"/>
            <arg column="locked_at" javaType="java.time.Instant"/>
            <arg column="locked_by" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <resultMap id="DeliveryStatusCountResultMap" type="com.example.batch.console.domain.view.cluster.DeliveryStatusCountView">
        <constructor>
            <arg column="delivery_status" javaType="java.lang.String"/>
            <arg column="cnt" javaType="java.lang.Long"/>
        </constructor>
    </resultMap>

    <!-- 平台级 shedlock 表无 tenant_id,全表扫描即可;按 name 排序保证多次调用结果稳定。 -->
    <select id="shedlockAll" resultMap="ShedLockResultMap">
        select name,
               lock_until,
               locked_at,
               locked_by
          from batch.shedlock
         order by name
    </select>

    <select id="eventDeliveryStatusCounts" resultMap="DeliveryStatusCountResultMap">
        select delivery_status,
               count(*) as cnt
          from batch.event_delivery_log
         where tenant_id = #{tenantId}
         group by delivery_status
    </select>

    <select id="countPendingOutboxEvents" resultType="java.lang.Long">
        select count(*)
          from batch.outbox_event
         where tenant_id = #{tenantId}
           and publish_status = 'NEW'
    </select>
</mapper>
