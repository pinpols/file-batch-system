<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.batch.console.mapper.JobDefinitionMapper">
    <resultMap id="JobDefinitionResultMap" type="com.example.batch.console.domain.entity.JobDefinitionEntity">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="job_code" property="jobCode"/>
        <result column="job_name" property="jobName"/>
        <result column="job_type" property="jobType"/>
        <result column="queue_code" property="queueCode"/>
        <result column="worker_group" property="workerGroup"/>
        <result column="schedule_type" property="scheduleType"/>
        <result column="schedule_expr" property="scheduleExpr"/>
        <result column="calendar_code" property="calendarCode"/>
        <result column="window_code" property="windowCode"/>
        <result column="retry_policy" property="retryPolicy"/>
        <result column="retry_max_count" property="retryMaxCount"/>
        <result column="timeout_seconds" property="timeoutSeconds"/>
        <result column="shard_strategy" property="shardStrategy"/>
        <result column="execution_handler" property="executionHandler"/>
        <result column="param_schema" property="paramSchema"/>
        <result column="default_params" property="defaultParams"/>
        <result column="description" property="description"/>
        <result column="enabled" property="enabled"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectByQuery" resultMap="JobDefinitionResultMap">
        select *
        from batch.job_definition
        where tenant_id = #{tenantId}
        <if test="jobCode != null and jobCode != ''">
            and job_code = #{jobCode}
        </if>
        <if test="jobType != null and jobType != ''">
            and job_type = #{jobType}
        </if>
        <if test="enabled != null">
            and enabled = #{enabled}
        </if>
        order by id desc
        <if test="pageRequest != null">
            <bind name="offset" value="(pageRequest.pageNo - 1) * pageRequest.pageSize"/>
            limit #{pageRequest.pageSize}
            offset #{offset}
        </if>
    </select>

    <select id="countByQuery" resultType="long">
        select count(1)
        from batch.job_definition
        where tenant_id = #{tenantId}
        <if test="jobCode != null and jobCode != ''">
            and job_code = #{jobCode}
        </if>
        <if test="jobType != null and jobType != ''">
            and job_type = #{jobType}
        </if>
        <if test="enabled != null">
            and enabled = #{enabled}
        </if>
    </select>

    <select id="selectByUniqueKey" resultMap="JobDefinitionResultMap">
        select *
        from batch.job_definition
        where tenant_id = #{tenantId}
          and job_code = #{jobCode}
    </select>

    <update id="updateJobDefinitionMaintenance">
        update batch.job_definition
        set job_name = #{jobName},
            queue_code = #{queueCode},
            worker_group = #{workerGroup},
            schedule_expr = #{scheduleExpr},
            calendar_code = #{calendarCode},
            window_code = #{windowCode},
            retry_policy = #{retryPolicy},
            retry_max_count = #{retryMaxCount},
            timeout_seconds = #{timeoutSeconds},
            shard_strategy = #{shardStrategy},
            enabled = #{enabled},
            description = #{description},
            updated_by = #{updatedBy},
            updated_at = current_timestamp
        where tenant_id = #{tenantId}
          and job_code = #{jobCode}
    </update>
</mapper>
