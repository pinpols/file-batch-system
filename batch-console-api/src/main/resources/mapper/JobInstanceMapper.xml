<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.batch.console.mapper.JobInstanceMapper">
    <resultMap id="JobInstanceResultMap" type="com.example.batch.console.domain.entity.JobInstanceEntity">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="job_code" property="jobCode"/>
        <result column="instance_no" property="instanceNo"/>
        <result column="biz_date" property="bizDate"/>
        <result column="trigger_type" property="triggerType"/>
        <result column="instance_status" property="instanceStatus"/>
        <result column="batch_no" property="batchNo"/>
        <result column="operator_id" property="operatorId"/>
        <result column="rerun_flag" property="rerunFlag"/>
        <result column="retry_flag" property="retryFlag"/>
        <result column="rerun_reason" property="rerunReason"/>
        <result column="related_file_id" property="relatedFileId"/>
        <result column="parent_instance_id" property="parentInstanceId"/>
        <result column="queue_code" property="queueCode"/>
        <result column="worker_group" property="workerGroup"/>
        <result column="priority" property="priority"/>
        <result column="trace_id" property="traceId"/>
        <result column="params_snapshot" property="paramsSnapshot"/>
        <result column="high_water_mark_in" property="highWaterMarkIn"/>
        <result column="high_water_mark_out" property="highWaterMarkOut"/>
        <result column="result_summary" property="resultSummary"/>
        <result column="deadline_at" property="deadlineAt"/>
        <result column="expected_duration_seconds" property="expectedDurationSeconds"/>
        <result column="sla_alerted_at" property="slaAlertedAt"/>
        <result column="started_at" property="startedAt"/>
        <result column="finished_at" property="finishedAt"/>
    </resultMap>

    <select id="selectByQuery" resultMap="JobInstanceResultMap">
        select *
        from batch.job_instance
        where tenant_id = #{tenantId}
        <if test="jobCode != null and jobCode != ''">
            and job_code like concat('%', #{jobCode}, '%')
        </if>
        <if test="instanceStatus != null and instanceStatus != ''">
            and instance_status = #{instanceStatus}
        </if>
        <if test="instanceNo != null and instanceNo != ''">
            and instance_no = #{instanceNo}
        </if>
        <if test="bizDate != null and bizDate != ''">
            and cast(biz_date as varchar) = #{bizDate}
        </if>
        <if test="traceId != null and traceId != ''">
            and trace_id like concat('%', #{traceId}, '%')
        </if>
        <if test="startedFrom != null">
            and started_at &gt;= #{startedFrom}
        </if>
        <if test="startedTo != null">
            and started_at &lt;= #{startedTo}
        </if>
        <if test="minDurationSeconds != null">
            and extract(epoch from (coalesce(finished_at, current_timestamp) - coalesce(started_at, created_at))) &gt;= #{minDurationSeconds}
        </if>
        <choose>
            <when test="sortBy == 'duration'">
                order by (coalesce(finished_at, current_timestamp) - coalesce(started_at, created_at)) desc
            </when>
            <otherwise>
                order by id desc
            </otherwise>
        </choose>
        <if test="pageRequest != null">
            <bind name="offset" value="(pageRequest.pageNo - 1) * pageRequest.pageSize"/>
            limit #{pageRequest.pageSize}
            offset #{offset}
        </if>
    </select>

    <select id="selectById" resultMap="JobInstanceResultMap">
        select *
        from batch.job_instance
        where tenant_id = #{tenantId}
          and id = #{id}
    </select>

    <select id="countByQuery" resultType="long">
        select count(1)
        from batch.job_instance
        where tenant_id = #{tenantId}
        <if test="jobCode != null and jobCode != ''">
            and job_code like concat('%', #{jobCode}, '%')
        </if>
        <if test="instanceStatus != null and instanceStatus != ''">
            and instance_status = #{instanceStatus}
        </if>
        <if test="instanceNo != null and instanceNo != ''">
            and instance_no = #{instanceNo}
        </if>
        <if test="bizDate != null and bizDate != ''">
            and cast(biz_date as varchar) = #{bizDate}
        </if>
        <if test="traceId != null and traceId != ''">
            and trace_id like concat('%', #{traceId}, '%')
        </if>
        <if test="startedFrom != null">
            and started_at &gt;= #{startedFrom}
        </if>
        <if test="startedTo != null">
            and started_at &lt;= #{startedTo}
        </if>
        <if test="minDurationSeconds != null">
            and extract(epoch from (coalesce(finished_at, current_timestamp) - coalesce(started_at, created_at))) &gt;= #{minDurationSeconds}
        </if>
    </select>

    <select id="countByStatuses" resultType="long">
        select count(1)
        from batch.job_instance
        where tenant_id = #{tenantId}
          and instance_status in
        <foreach collection="statuses" item="status" open="(" close=")" separator=",">
            #{status}
        </foreach>
    </select>

    <select id="countSlaBreaches" resultType="long">
        select count(1)
        from batch.job_instance
        where tenant_id = #{tenantId}
          and deadline_at is not null
          and deadline_at &lt; current_timestamp
          and instance_status in
        <foreach collection="activeStatuses" item="status" open="(" close=")" separator=",">
            #{status}
        </foreach>
    </select>

    <select id="selectByInstanceNos" resultMap="JobInstanceResultMap">
        select *
        from batch.job_instance
        where tenant_id = #{tenantId}
          and instance_no in
        <foreach collection="instanceNos" item="no" open="(" close=")" separator=",">
            #{no}
        </foreach>
        order by id desc
    </select>
</mapper>
