<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.batch.console.mapper.ConsoleBusinessTenantPlacementMapper">

    <resultMap id="placementMap"
               type="com.example.batch.common.persistence.entity.BusinessTenantPlacementEntity">
        <id column="tenant_id" property="tenantId"/>
        <result column="placement_key" property="placementKey"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="updated_by" property="updatedBy"/>
    </resultMap>

    <!-- 平台 admin 全局映射视图:本表本身就是「租户→片」的全量,刻意不按 tenant 过滤(无条件,非 <if> 守护)。 -->
    <select id="findAll" resultMap="placementMap">
        select tenant_id, placement_key, updated_at, updated_by
          from batch.business_tenant_placement
         order by placement_key, tenant_id
    </select>

    <insert id="upsert">
        insert into batch.business_tenant_placement (tenant_id, placement_key, updated_by)
        values (#{p.tenantId}, #{p.placementKey}, #{p.operator})
        on conflict (tenant_id) do update
            set placement_key = #{p.placementKey},
                updated_by    = #{p.operator},
                updated_at    = current_timestamp
    </insert>

    <delete id="deleteByTenant">
        delete from batch.business_tenant_placement where tenant_id = #{tenantId}
    </delete>

</mapper>
