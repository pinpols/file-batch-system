<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 继承 Spring Boot 默认配置（控制台输出、日志级别等保持不变） -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- 前端遥测专属文件 appender - local profile -->
    <!-- 用 FileAppender + append=false，与 start-all.sh 其他模块日志（shell > 重定向覆盖）行为完全对齐：
         单文件、每次启动覆盖、不产生 frontend.YYYY-MM-DD.N.log 归档。
         生产 profile 仍保留 RollingFileAppender 做日志审计留痕。 -->
    <springProfile name="local">
        <appender name="FRONTEND_FILE" class="ch.qos.logback.core.FileAppender">
            <file>logs/app/frontend.log</file>
            <append>false</append>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%X{frontendApp}][%X{frontendUserId}][%X{frontendPage}] %msg%n</pattern>
            </encoder>
        </appender>

        <logger name="com.example.batch.console.web.ConsoleTelemetryController"
                level="INFO" additivity="false">
            <appender-ref ref="FRONTEND_FILE"/>
        </logger>
    </springProfile>

    <!-- 前端遥测专属文件 appender - 生产部署（非 local、非 test、非 e2e） -->
    <!-- 使用 & 表达式确保测试环境不尝试创建 /logs/ 绝对路径 -->
    <springProfile name="!local &amp; !test &amp; !e2e">
        <appender name="FRONTEND_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>/logs/frontend.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>/logs/frontend.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>14</maxHistory>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%X{frontendApp}][%X{frontendUserId}][%X{frontendPage}] %msg%n</pattern>
            </encoder>
        </appender>

        <logger name="com.example.batch.console.web.ConsoleTelemetryController"
                level="INFO" additivity="false">
            <appender-ref ref="FRONTEND_FILE"/>
        </logger>
    </springProfile>

    <!-- 测试环境（test / e2e profile）：前端遥测日志退化到控制台，不写文件 -->
    <springProfile name="test,e2e">
        <logger name="com.example.batch.console.web.ConsoleTelemetryController"
                level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
    </springProfile>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
