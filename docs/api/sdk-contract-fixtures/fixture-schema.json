{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/file-batch-system/sdk-contract-fixtures/fixture-schema.json",
  "title": "SDK Contract Fixture",
  "description": "Schema for language-agnostic SDK contract fixtures consumed by Java JsonFixtureContractTest and Python contract runner. Lane P (drift guard).",
  "type": "object",
  "required": ["scenario", "description", "given", "when", "then"],
  "additionalProperties": false,
  "properties": {
    "scenario": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "minLength": 3,
      "maxLength": 80,
      "description": "kebab-case unique scenario id"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "given": {
      "type": "object",
      "required": ["config"],
      "additionalProperties": false,
      "properties": {
        "config": {
          "type": "object",
          "description": "SDK boot config (tenantId / workerCode / ...). Schema intentionally open."
        },
        "state": {
          "type": "object",
          "description": "Optional simulated SDK state (in-flight tasks, FSM state, etc)."
        }
      }
    },
    "when": {
      "type": "object",
      "required": ["channel", "method"],
      "additionalProperties": false,
      "properties": {
        "channel": {
          "type": "string",
          "enum": ["http", "kafka"]
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "DELETE", "PATCH", "RECEIVE"]
        },
        "path": {
          "type": "string",
          "description": "HTTP path (for channel=http); kebab/slash form, must start with /internal/."
        },
        "topic": {
          "type": "string",
          "description": "Kafka topic / pattern (optional, for channel=kafka)."
        },
        "body": {
          "description": "Outgoing request body or incoming kafka payload."
        },
        "responseStatus": {
          "type": ["integer", "null"],
          "minimum": 100,
          "maximum": 599
        },
        "responseBody": {
          "description": "Platform response payload (null for kafka receive)."
        },
        "responseHeaders": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "if": { "properties": { "channel": { "const": "http" } }, "required": ["channel"] },
          "then": { "required": ["path", "responseStatus"] }
        }
      ]
    },
    "then": {
      "type": "object",
      "required": ["sdkExpectedAction", "expect"],
      "additionalProperties": false,
      "properties": {
        "sdkExpectedAction": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable description of behavior the SDK MUST exhibit."
        },
        "sdkMustNot": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "expect": {
          "type": "object",
          "additionalProperties": false,
          "description": "Machine-assertable expectation (BYO conformance). Optional but RECOMMENDED: every language runner asserts these discrete fields identically, instead of parsing the human-readable sdkExpectedAction prose. Closed vocabulary — adding a field requires a schema bump so expectations themselves cannot drift.",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "register-online",
                "apply-directive",
                "fail-fast",
                "idempotent-success",
                "retry-then-drop",
                "cancel",
                "backpressure",
                "graceful-stop"
              ],
              "description": "Primary SDK action the response/message must trigger."
            },
            "retry": { "type": "boolean", "description": "Whether the SDK retries this call." },
            "retryBackoffMs": {
              "type": "array",
              "items": { "type": "integer", "minimum": 0 },
              "description": "Expected sleep sequence between attempts, e.g. [200,400,800]."
            },
            "maxAttempts": { "type": "integer", "minimum": 1 },
            "failFast": {
              "type": "boolean",
              "description": "Mark dispatcher fatal and stop accepting tasks."
            },
            "fsmTransition": {
              "type": ["string", "null"],
              "enum": ["NORMAL", "DEGRADED", "PAUSED", "DRAINING", null],
              "description": "Target worker FSM state, or null when unchanged."
            },
            "kafka": {
              "type": "string",
              "enum": ["none", "subscribe", "pause", "resume", "wakeup", "drop-message"],
              "description": "Required Kafka consumer action."
            },
            "startSchedulers": {
              "type": "array",
              "items": { "type": "string", "enum": ["heartbeat", "leaseRenew"] }
            },
            "heartbeatNextIntervalMs": {
              "type": "integer",
              "minimum": 0,
              "description": "Effective next heartbeat interval after applying nextHeartbeatHint."
            },
            "cancelRequested": { "type": "boolean" },
            "idempotent": { "type": "boolean" },
            "reportFailure": {
              "type": "boolean",
              "description": "Whether the SDK reports a task FAILURE for this scenario."
            },
            "deactivate": { "type": "boolean", "description": "Calls POST /deactivate." },
            "drainThenDeactivate": { "type": "boolean" },
            "resumeWhenDrained": { "type": "boolean" },
            "withinMs": {
              "type": "integer",
              "minimum": 0,
              "description": "Hard wall-clock bound the action must complete within (e.g. stop timeout)."
            }
          }
        }
      }
    },
    "references": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
