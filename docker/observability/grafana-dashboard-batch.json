{
  "title": "Batch Platform — baseline",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "batch_alert_events (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(batch_alert_events_total[5m])",
          "legendFormat": "{{alert_type}}/{{severity}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "batch_job_sla_violation_count",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "batch_job_sla_violation_count",
          "legendFormat": "violations"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM memory used",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{id}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "batch_dispatch_circuits_open",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "batch_dispatch_circuits_open",
          "legendFormat": "open circuits"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "batch_dispatch_deliveries_total (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(batch_dispatch_deliveries_total[5m])",
          "legendFormat": "{{channel_type}}/{{result}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HikariCP active / idle",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "hikaricp_connections_active",
          "legendFormat": "{{pool}} active"
        },
        {
          "expr": "hikaricp_connections_idle",
          "legendFormat": "{{pool}} idle"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HikariCP pending / max",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "hikaricp_connections_pending",
          "legendFormat": "{{pool}} pending"
        },
        {
          "expr": "hikaricp_connections_max",
          "legendFormat": "{{pool}} max"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis overview",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "up{job=\"redis-exporter\"}",
          "legendFormat": "redis exporter up"
        },
        {
          "expr": "redis_connected_clients",
          "legendFormat": "connected clients"
        },
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "memory used"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Kafka exporter / consumer lag",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "up{job=\"kafka-exporter\"}",
          "legendFormat": "kafka exporter up"
        },
        {
          "expr": "kafka_brokers",
          "legendFormat": "brokers"
        },
        {
          "expr": "kafka_consumergroup_lag{consumergroup=~\"batch-worker-(import|export|dispatch)\"}",
          "legendFormat": "{{consumergroup}}/{{topic}}/{{partition}} lag"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "PostgreSQL exporter",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "pg_up",
          "legendFormat": "pg up"
        },
        {
          "expr": "pg_stat_database_numbackends",
          "legendFormat": "connections"
        },
        {
          "expr": "pg_stat_database_xact_commit",
          "legendFormat": "commits"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "MinIO health / capacity",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "targets": [
        {
          "expr": "up{job=\"minio\"}",
          "legendFormat": "minio up"
        },
        {
          "expr": "minio_cluster_nodes_offline_total",
          "legendFormat": "offline nodes"
        },
        {
          "expr": "minio_cluster_capacity_raw_total_bytes",
          "legendFormat": "capacity total"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP QPS",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 48 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[5m])) by (job)",
          "legendFormat": "{{job}} qps"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Host CPU / load",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 56 },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}} cpu used %"
        },
        {
          "expr": "node_load1",
          "legendFormat": "{{instance}} load1"
        },
        {
          "expr": "node_load5",
          "legendFormat": "{{instance}} load5"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Host memory / disk",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 56 },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "{{instance}} mem used %"
        },
        {
          "expr": "100 * (1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}))",
          "legendFormat": "{{instance}} disk used %"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Host network",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 64 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*\"}[5m])",
          "legendFormat": "{{instance}} rx bytes/s"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*\"}[5m])",
          "legendFormat": "{{instance}} tx bytes/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container CPU / memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 64 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{image!=\"\"}[5m])) by (name)",
          "legendFormat": "{{name}} cpu cores"
        },
        {
          "expr": "sum(container_memory_working_set_bytes{image!=\"\"}) by (name)",
          "legendFormat": "{{name}} working set"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container network / fs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 72 },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{image!=\"\"}[5m])) by (name)",
          "legendFormat": "{{name}} rx bytes/s"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{image!=\"\"}[5m])) by (name)",
          "legendFormat": "{{name}} tx bytes/s"
        },
        {
          "expr": "sum(container_fs_usage_bytes{image!=\"\"}) by (name)",
          "legendFormat": "{{name}} fs bytes"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Outbox events rate (R7-A6)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 80 },
      "targets": [
        { "expr": "rate(batch_outbox_events_published_total[5m])", "legendFormat": "published" },
        { "expr": "rate(batch_outbox_events_failed_total[5m])", "legendFormat": "failed" },
        { "expr": "rate(batch_outbox_events_give_up_total[5m])", "legendFormat": "give_up (alert!)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Outbox stale / pending (R7-A6)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 80 },
      "targets": [
        { "expr": "batch_outbox_publishing_stale_events", "legendFormat": "stale PUBLISHING" },
        { "expr": "batch_outbox_pending_events", "legendFormat": "pending" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Trigger outbox rates (R7-A6)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 88 },
      "targets": [
        { "expr": "rate(batch_trigger_launch_published_total[5m])", "legendFormat": "trigger published" },
        { "expr": "rate(batch_trigger_launch_consumed_total[5m])", "legendFormat": "consumer consumed" },
        { "expr": "rate(batch_trigger_outbox_give_up_total[5m])", "legendFormat": "give_up (alert!)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Trigger publish latency p99 (R7-A6)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 88 },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(batch_trigger_outbox_publish_latency_seconds_bucket{result=\"ok\"}[5m])) by (le))", "legendFormat": "ok p99" },
        { "expr": "histogram_quantile(0.99, sum(rate(batch_trigger_outbox_publish_latency_seconds_bucket{result=\"fail\"}[5m])) by (le))", "legendFormat": "fail p99" }
      ]
    }
  ],
  "uid": "batch-platform-baseline",
  "editable": true
}
