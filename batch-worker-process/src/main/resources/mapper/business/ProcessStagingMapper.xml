<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.batch.worker.processes.mapper.business.ProcessStagingMapper">

    <!--
      孤儿清理：staged_at 早于 retentionHours 小时的行，单次最多删 batchSize 条。
      WHERE ctid IN (SELECT ctid ... LIMIT) 把锁范围限制在选中的物理行。
      ORDER BY staged_at 优先清最老的行。
    -->
    <delete id="deleteOrphansOlderThan">
        DELETE FROM batch.process_staging
        WHERE ctid IN (
          SELECT ctid FROM batch.process_staging
          WHERE staged_at &lt; now() - make_interval(hours => #{retentionHours})
          ORDER BY staged_at
          LIMIT #{batchSize}
        )
    </delete>

    <select id="selectMinStagedAt" resultType="java.time.Instant">
        SELECT min(staged_at) FROM batch.process_staging
    </select>

</mapper>
