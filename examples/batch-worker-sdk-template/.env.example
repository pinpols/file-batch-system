# batch-worker-sdk-template — env 变量清单
# 拷贝成 .env(.env 已加 .gitignore,绝不提交)
# 凭据走 env(R3-11 envRef 风格预备):api-key / SASL 密码 一律不写明文配置文件

# ---- 平台接入 ----
BATCH_BASE_URL=http://host.docker.internal:8081
BATCH_API_KEY=                    # ★ 必填(prod);本地联调允许空
BATCH_TENANT_ID=tenant-demo
BATCH_WORKER_CODE=tenant-demo-worker-1

# ---- Kafka ----
BATCH_KAFKA=host.docker.internal:9092
BATCH_TOPIC_PATTERN=batch.task.dispatch.tenant-demo.*
BATCH_KAFKA_GROUP=tenant-demo-workers

# ---- Kafka SASL/SCRAM(prod 必填,本地 PLAINTEXT 留空) ----
BATCH_KAFKA_PROTOCOL=
BATCH_KAFKA_SASL_MECHANISM=
BATCH_KAFKA_SASL_JAAS=

# ---- 运行时 ----
BATCH_BUILD_ID=dev                # CI 注入 git short-SHA / image tag
BATCH_MAX_CONCURRENT=4

# ---- JVM(可选 override Dockerfile 默认) ----
# JAVA_OPTS=-XX:+UseG1GC -XX:MaxRAMPercentage=75.0 -Dfile.encoding=UTF-8
