<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.batch.trigger.mapper.BusinessCalendarMapper">
    <resultMap id="TriggerCalendarConfigResultMap" type="com.example.batch.trigger.support.TriggerCalendarConfig">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="calendar_code" property="calendarCode"/>
        <result column="timezone" property="timezone"/>
        <result column="holiday_roll_rule" property="holidayRollRule"/>
        <result column="cutoff_time" property="cutoffTime"/>
    </resultMap>

    <resultMap id="CalendarHolidayRuleResultMap" type="com.example.batch.trigger.support.CalendarHolidayRule">
        <result column="biz_date" property="bizDate"/>
        <result column="day_type" property="dayType"/>
    </resultMap>

    <select id="selectActiveByTenantAndCalendarCode" resultMap="TriggerCalendarConfigResultMap">
        select
            id,
            tenant_id,
            calendar_code,
            timezone,
            holiday_roll_rule,
            cutoff_time
        from batch.business_calendar
        where tenant_id = #{tenantId}
          and calendar_code = #{calendarCode}
          and enabled = true
    </select>

    <select id="selectHolidayRulesByCalendarId" resultMap="CalendarHolidayRuleResultMap">
        select
            biz_date,
            day_type
        from batch.calendar_holiday
        where calendar_id = #{calendarId}
    </select>
</mapper>
