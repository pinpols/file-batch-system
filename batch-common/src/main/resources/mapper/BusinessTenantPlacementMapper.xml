<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.pinpols.batch.common.mapper.BusinessTenantPlacementMapper">

    <resultMap id="placementResult"
               type="io.github.pinpols.batch.common.persistence.entity.BusinessTenantPlacementEntity">
        <result property="tenantId" column="tenant_id"/>
        <result property="placementKey" column="placement_key"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="updatedBy" column="updated_by"/>
    </resultMap>

    <select id="selectAll" resultMap="placementResult">
        SELECT tenant_id, placement_key, updated_at, updated_by
          FROM batch.business_tenant_placement
    </select>

</mapper>
